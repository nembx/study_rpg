{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Study RPG",
  "version": "0.1.0",
  "identifier": "com.nembx.studyrpg",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "companion",
        "title": "Study RPG Companion",
        "width": 280,
        "height": 160,
        "resizable": false,
        "visible": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "dashboard",
        "title": "Study RPG",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
